# RoyalSauna — environment variables
# Skopiuj ten plik do .env.local i uzupełnij wartości.

# Pełny adres produkcyjny strony (bez końcowego ukośnika), np. https://royalsauna.pl
NEXT_PUBLIC_SITE_URL=

# Meta (Facebook) Pixel ID — np. 123456789012345
NEXT_PUBLIC_META_PIXEL_ID=

# Microsoft Clarity Project ID — np. abcdefghij
NEXT_PUBLIC_CLARITY_ID=

# Cookiebot Domain Group ID — https://admin.cookiebot.com (Settings → Your scripts)
# Steruje banerem zgody i automatycznie blokuje GTM/Pixel/Clarity do czasu zgody.
NEXT_PUBLIC_COOKIEBOT_ID=

# Włącz placeholdery AI voice agent / chat widget (true|false)
NEXT_PUBLIC_ENABLE_AI_AGENT=false

# Resend — wysyłka maila z ofertą po wypełnieniu formularza
# https://resend.com/api-keys
RESEND_API_KEY=

# Nadawca maili z ofertą. Wymaga zweryfikowanej domeny w Resend
# (resend.com/domains) — inaczej maile pójdą tylko na adres właściciela konta.
OFFER_EMAIL_FROM=RoyalSauna <oferta@royalsauna.pl>

# Adres, na który idzie kopia (BCC) każdego zapytania z formularza
OFFER_NOTIFY_TO=biuro@royalsauna.pl

# Ścieżka do pliku PDF z ofertą dołączanego do maila (względna do katalogu głównego)
OFFER_PDF_PATH=public/documents/oferta.pdf
